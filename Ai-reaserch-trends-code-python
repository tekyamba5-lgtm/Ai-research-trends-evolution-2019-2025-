    os.makedirs(os.path.dirname(path), exist_ok=True)
    plt.savefig(path, dpi=300, bbox_inches="tight")
    print("✅ Image enregistrée :", path)
except Exception as e:
    print("❌ Erreur sauvegarde :", e)

